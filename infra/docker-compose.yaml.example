services:
  db:
    image: postgres:18.3-alpine3.23
    container_name: "postgresql_edop"
    restart: always
    shm_size: 128mb
    environment:
      POSTGRES_PASSWORD: <DB_PASSWORD>
      POSTGRES_USER: <DB_USERNAME>
      POSTGRES_DB: edop
    ports:
      - "5432:5432"
    volumes:
      - postgresql_data_edop:/var/lib/postgresql/data

volumes:
  postgresql_data_edop:
    driver: local
